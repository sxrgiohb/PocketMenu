<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base theme -->
    <style name="Base.Theme.PocketMenu" parent="Theme.Material3.Light.NoActionBar">

        <!-- Default font -->
        <item name="android:fontFamily">@font/quicksand_bold</item>

        <!-- Primary colors -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/on_primary</item>

        <!-- Secondary colors -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/on_secondary</item>

        <!-- Tertiary colors -->
        <item name="colorTertiary">@color/tertiary</item>
        <item name="colorOnTertiary">@color/on_tertiary</item>

        <!-- Background -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>

        <!-- Text -->
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorOnSurface">@color/text_primary</item>

        <!-- Component styles -->
        <item name="floatingActionButtonStyle">@style/MyFAB</item>
        <item name="checkboxStyle">@style/MyCheckBox</item>
        <item name="materialCardViewStyle">@style/MyCard</item>
        <item name="actionBarTheme">@style/MyActionBarTheme</item>

        <!-- Apply custom Filter Chip style -->
        <item name="chipStyle">@style/Widget.MyApp.Chip.Filter</item>

    </style>

    <!-- Final app theme -->
    <style name="Theme.PocketMenu" parent="Base.Theme.PocketMenu" />

    <!-- Floating Action Button -->
    <style name="MyFAB" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">@color/secondary</item>
        <item name="tint">@color/on_secondary</item>
        <item name="rippleColor">@color/primary</item>
    </style>

    <!-- Standard Button -->
    <style name="MyButton" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/secondary</item>
        <item name="android:textColor">@color/on_secondary</item>
        <item name="rippleColor">@color/on_primary</item>
    </style>

    <!-- Icon Buttons -->
    <style name="FavoriteButton" parent="Widget.Material3.Button.IconButton">
        <item name="iconTint">@color/red</item>
        <item name="rippleColor">@android:color/transparent</item>
    </style>

    <style name="EditButton" parent="Widget.Material3.Button.IconButton">
        <item name="iconTint">@color/black</item>
        <item name="rippleColor">@android:color/transparent</item>
    </style>

    <style name="AddRecipeButton" parent="Widget.Material3.Button.IconButton">
        <item name="iconTint">@color/black</item>
        <item name="rippleColor">@android:color/transparent</item>
    </style>

    <style name="AddLeftoverButton" parent="Widget.Material3.Button.IconButton">
        <item name="iconTint">@color/black</item>
        <item name="rippleColor">@android:color/transparent</item>
    </style>

    <style name="InfoButton" parent="Widget.Material3.Button.IconButton">
        <item name="iconTint">@color/secondary</item>
        <item name="rippleColor">@android:color/transparent</item>
    </style>

    <style name="SeeMoreButton" parent="Widget.Material3.Button.IconButton">
        <item name="iconTint">@color/secondary</item>
        <item name="rippleColor">@android:color/transparent</item>
    </style>

    <style name="SeeLessButton" parent="Widget.Material3.Button.IconButton">
        <item name="iconTint">@color/secondary</item>
        <item name="rippleColor">@android:color/transparent</item>
    </style>

    <style name="DeleteButton" parent="Widget.Material3.Button.IconButton">
        <item name="iconTint">@color/secondary</item>
        <item name="rippleColor">@android:color/transparent</item>
    </style>

    <!-- CheckBox -->
    <style name="MyCheckBox" parent="Widget.Material3.CompoundButton.CheckBox">
        <item name="buttonTint">@color/primary</item>
    </style>

    <!-- Card -->
    <style name="MyCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="cardElevation">4dp</item>
        <item name="strokeColor">@color/background</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- ActionBar -->
    <style name="MyActionBarTheme" parent="ThemeOverlay.Material3.ActionBar">
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="iconTint">@color/primary</item>
    </style>

    <!-- Custom Filter Chip -->
    <style name="Widget.MyApp.Chip.Filter" parent="Widget.Material3.Chip.Filter">
        <!-- Background -->
        <item name="chipBackgroundColor">@color/chip_filter_background</item>
        <!-- Text -->
        <item name="android:textColor">@color/chip_text_color</item>
        <!-- Remove tick -->
        <item name="chipIcon">@null</item>
        <item name="checkedIcon">@null</item>
        <!-- Border -->
        <item name="chipStrokeWidth">0dp</item>
    </style>

</resources>