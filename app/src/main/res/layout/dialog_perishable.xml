<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Text -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/is_parishable"
        android:textSize="16sp"
        android:layout_marginBottom="12dp" />

    <!-- Perishable switch -->
    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/switch_perishable"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/perishable"
        android:layout_marginBottom="16dp" />

    <!-- Perishable days input -->
    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:id="@+id/layout_valid_days"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/leftovers_last"
        android:visibility="gone">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edit_valid_days"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number" />

    </com.google.android.material.textfield.TextInputLayout>

</LinearLayout>
